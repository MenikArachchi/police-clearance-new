# User/auth database (t_user_registration)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=common_user_police

# Application/clearance database (application, address, comments, etc.)
APP_DB_HOST=localhost
APP_DB_PORT=3306
APP_DB_USER=root
APP_DB_PASSWORD=
APP_DB_NAME=police_db

# Path to the directory where uploaded attachment files are stored
UPLOAD_FILE_PATH=/path/to/uploads

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production
NEXTAUTH_URL=http://localhost:3000

# Base path — leave empty for dev. Set to /admin-new on production server.
# NEXT_BASE_PATH=
# NEXT_PUBLIC_BASE_PATH=
