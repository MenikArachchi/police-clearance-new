<?xml version="1.0" encoding="UTF-8"?>
<web-app id="police_citizen_app" version="2.4"
         xmlns="http://java.sun.com/xml/ns/j2ee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
    <display-name>POLICE Citizen App</display-name>
    <filter>
        <filter-name>struts2</filter-name>
        <filter-class>org.apache.struts2.dispatcher.ng.filter.StrutsPrepareAndExecuteFilter</filter-class>
    </filter>
    
    <filter-mapping>
        <filter-name>struts2</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
   
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    
    <resource-ref>
		<description>DB Connection</description>
		<res-ref-name>jdbc/POLDB</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>
	
	<servlet>
		<servlet-name>CaptchaServlet</servlet-name>
		<servlet-class>lk.icta.police.web.servlet.CaptchaGeneratorServlet</servlet-class>
		<init-param>
			<description>passing height</description>
			<param-name>height</param-name>
			<param-value>20</param-value>
		</init-param>
		<init-param>
			<description>passing height</description>
			<param-name>width</param-name>
			<param-value>58</param-value>
		</init-param>
	</servlet>
	<servlet-mapping>
		<servlet-name>CaptchaServlet</servlet-name>
		<url-pattern>/Captcha.jpg</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<description></description>
		<display-name>ReportFileFinder</display-name>
		<servlet-name>ReportFileFinder</servlet-name>
		<servlet-class>lk.icta.police.web.servlet.ReportFileFinder</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ReportFileFinder</servlet-name>
		<url-pattern>/reportfilefinder.htm</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<description></description>
		<display-name>PoliceFileFinder</display-name>
		<servlet-name>PoliceFileFinder</servlet-name>
		<servlet-class>lk.icta.police.web.servlet.PoliceFileFinder</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>PoliceFileFinder</servlet-name>
		<url-pattern>/policeFileFinder.htm</url-pattern>
	</servlet-mapping>
	
	<security-constraint>
 		<web-resource-collection>
 	 	<web-resource-name>restricted methods</web-resource-name>
  			<url-pattern>/*</url-pattern>
  			<http-method>PUT</http-method>
  			<http-method>DELETE</http-method>
  			<http-method>OPTIONS</http-method>
  			<http-method>TRACE</http-method>
  			<http-method>HEAD</http-method>
 		</web-resource-collection>
 		<auth-constraint />
	</security-constraint>
    
    <error-page>
		<error-code>400</error-code>
		<location>/errorpages/error_400.jsp</location>
	</error-page>
	<error-page>
		<error-code>401</error-code>
		<location>/errorpages/error_401.jsp</location>
	</error-page>
	<error-page>
		<error-code>403</error-code>
		<location>/errorpages/error_403.jsp</location>
	</error-page>
  	<error-page>
		<error-code>404</error-code>
		<location>/errorpages/error_404.jsp</location>
	</error-page>
	<error-page>
		<error-code>500</error-code>
		<location>/errorpages/error_500.jsp</location>
	</error-page> 
	<error-page>
	  <exception-type>java.lang.Throwable</exception-type>
	  <location>/errorpages/error_500.jsp</location>
	</error-page>
	
	<session-config>
	 <session-timeout>30</session-timeout>
		<cookie-config>
        	<http-only>true</http-only>
        	<secure>false</secure>
      	</cookie-config>
      	 <tracking-mode>COOKIE</tracking-mode>	   
	</session-config>
   
    
</web-app>
