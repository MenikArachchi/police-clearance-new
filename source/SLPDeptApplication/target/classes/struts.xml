<struts>
    <constant name="struts.custom.i18n.resources" value="global,police"/>
    <constant name="struts.enable.DynamicMethodInvocation" value="false"/>
    <constant name="struts.devMode" value="false"/>
    <constant name="struts.multipart.maxSize" value="250000"/>
    <constant name="struts.i18n.encoding" value="UTF-8"></constant>


    <package name="default" extends="struts-default,json-default" namespace="/">
        <interceptors>
            <!-- login intercepter -->
            <interceptor name="loginIntercepter" class="lk.icta.police.action.LoginInterceptor"/>

            <!-- 			<interceptor name="xssInterceptor" class="lk.icta.police.util.XssInterceptor" />  -->

            <!-- stack to be used for internationalisation functionality -->
            <interceptor-stack name="customI18nStack">
                <interceptor-ref name="i18n">
                    <param name="parameterName">lang</param>
                </interceptor-ref>
                <interceptor-ref name="basicStack"/>
            </interceptor-stack>

            <interceptor-stack name="myStack">
                <interceptor-ref name="loginIntercepter"/>
                <interceptor-ref name="customI18nStack"/>
                <interceptor-ref name="defaultStack"/>
            </interceptor-stack>
        </interceptors>

        <default-interceptor-ref name="myStack"/>

        <!-- Login and Authorization - START -->
        <global-results>
            <result name="invalid-session" type="redirectAction">sessionInvalidate</result>
            <result name="unauthorized" type="redirectAction">unauthorized</result>
        </global-results>

        <action name="sessionInvalidate" class="lk.icta.police.action.SessionInvalidateAction"
                method="sessionInvalidated">
            <result>/WEB-INF/jsp/view/login.jsp</result>
            <result name="error">/WEB-INF/jsp/view/login.jsp</result>
            <result name="success">/WEB-INF/jsp/view/login.jsp</result>
        </action>

        <action name="unauthorized"
                class="lk.icta.police.action.SessionInvalidateAction" method="unauthorized">
            <result>/WEB-INF/jsp/view/home.jsp</result>
            <result name="error">/WEB-INF/jsp/view/login.jsp</result>
            <result name="success">/WEB-INF/jsp/view/home.jsp</result>
        </action>

        <action name="home" class="lk.icta.police.action.HomeAction">
            <result>/WEB-INF/jsp/view/home.jsp</result>
            <result name="error">/WEB-INF/jsp/view/home.jsp</result>
            <result name="success">/WEB-INF/jsp/view/home.jsp</result>
        </action>

        <action name="login">
            <result name="login">/WEB-INF/jsp/view/login.jsp</result>
            <result>/WEB-INF/jsp/view/login.jsp</result>
        </action>

        <action name="authorizationAction" class="lk.icta.police.action.AuthorizationAction">
            <!-- 			<interceptor-ref name="xssInterceptor"/> -->
            <interceptor-ref name="myStack"/>
            <result name="input">/WEB-INF/jsp/view/login.jsp</result>
            <result name="error">/WEB-INF/jsp/view/login.jsp</result>
            <result name="success" type="redirectAction">home</result>
        </action>

        <action name="logout" class="lk.icta.police.action.AuthorizationAction" method="doLogout">
            <result name="success">/WEB-INF/jsp/view/login.jsp</result>
            <result name="error">/WEB-INF/jsp/view/login.jsp</result>
            <result>/WEB-INF/jsp/view/login.jsp</result>
