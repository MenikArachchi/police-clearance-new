<?xml version="1.0" encoding="UTF-8"?>
<web-app id="doc_dept_app" version="2.4"
         xmlns="http://java.sun.com/xml/ns/j2ee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
    <display-name>POLICE Department App</display-name>
    
    <filter>
        <filter-name>loginSpecialFilter</filter-name>
        <filter-class>lk.icta.police.action.LoginFilter</filter-class>        
    </filter>
    
    <filter-mapping>
        <filter-name>loginSpecialFilter</filter-name>
        <url-pattern>*.htm</url-pattern>
    </filter-mapping>
    

    <filter>
        <filter-name>struts2</filter-name>
        <filter-class>org.apache.struts2.dispatcher.ng.filter.StrutsPrepareAndExecuteFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>struts2</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    
    <resource-ref>
		<description>DB Connection</description>
		<res-ref-name>jdbc/POLDB</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>
	
	<resource-ref>
		<description>DB Connection</description>
		<res-ref-name>jdbc/COMMUSRDB_SLP</res-ref-name>
		<res-type>javax.sql.DataSource</res-type>
		<res-auth>Container</res-auth>
	</resource-ref>
	
	<listener>
        <listener-class>lk.icta.police.util.CustomHttpSessionListener</listener-class>
	</listener>
	
	<servlet>
		<description></description>
		<display-name>ReportFileFinder</display-name>
		<servlet-name>ReportFileFinder</servlet-name>
		<servlet-class>lk.icta.police.servlet.ReportFileFinder</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>ReportFileFinder</servlet-name>
		<url-pattern>/reportfilefinder.htm</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<description></description>
		<display-name>PoliceFileFinder</display-name>
		<servlet-name>PoliceFileFinder</servlet-name>
		<servlet-class>lk.icta.police.servlet.PoliceFileFinder</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>PoliceFileFinder</servlet-name>
		<url-pattern>/policeFileFinder.htm</url-pattern>
	</servlet-mapping>
	

	<servlet>
		<servlet-name>CaptchaServlet</servlet-name>
		<servlet-class>lk.icta.police.servlet.CaptchaGeneratorServlet</servlet-class>
		<init-param>
			<description>passing height</description>
			<param-name>height</param-name>
			<param-value>20</param-value>
		</init-param>
		<init-param>
			<description>passing height</description>
			<param-name>width</param-name>
			<param-value>58</param-value>
		</init-param>
	</servlet>
	<servlet-mapping>
		<servlet-name>CaptchaServlet</servlet-name>
		<url-pattern>/Captcha.jpg</url-pattern>
	</servlet-mapping>
	
	
	<security-constraint>
 		<web-resource-collection>
 	 	<web-resource-name>restricted methods</web-resource-name>
  			<url-pattern>/*</url-pattern>
  			<http-method>PUT</http-method>
  			<http-method>DELETE</http-method>
  			<http-method>OPTIONS</http-method>
  			<http-method>TRACE</http-method>
  			<http-method>HEAD</http-method>
 		</web-resource-collection>
 		<auth-constraint />
	</security-constraint>
    
